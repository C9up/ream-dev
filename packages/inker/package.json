{
	"name": "@c9up/inker",
	"version": "0.1.0",
	"description": "Inker — server-side templating for the Ream framework. Hand-rolled lexer/parser/renderer with HTML-escape-by-default interpolation and .inker file convention.",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./provider": {
			"types": "./src/InkerProvider.ts",
			"import": "./src/InkerProvider.ts"
		},
		"./provider/services/main": {
			"types": "./src/services/main.ts",
			"import": "./src/services/main.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@c9up/ream": "workspace:*",
		"@c9up/rosetta": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@c9up/ream": {
			"optional": true
		},
		"@c9up/rosetta": {
			"optional": true
		}
	},
	"devDependencies": {
		"@c9up/ream": "workspace:*",
		"@c9up/rosetta": "workspace:*",
		"@types/node": "^22.19.15",
		"@vitest/coverage-v8": "^4.1.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"files": [
		"LICENSE",
		"README.md",
		"dist",
		"src"
	],
	"publishConfig": {
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			},
			"./provider": {
				"types": "./dist/InkerProvider.d.ts",
				"import": "./dist/InkerProvider.js"
			},
			"./provider/services/main": {
				"types": "./dist/services/main.d.ts",
				"import": "./dist/services/main.js"
			}
		}
	}
}
