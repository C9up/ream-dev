{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"experimentalDecorators": true,
		"strict": false,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true
	},
	"include": ["app/**/*.ts", "config/**/*.ts"]
}
