{
	"name": "@c9up/nova",
	"version": "0.1.0",
	"description": "Nova — Web Push notifications for Ream (VAPID + subscription endpoint + service worker scaffolding)",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"dist",
		"migrations",
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./provider": {
			"types": "./src/NovaProvider.ts",
			"import": "./src/NovaProvider.ts"
		},
		"./services/main": {
			"types": "./src/services/main.ts",
			"import": "./src/services/main.ts"
		},
		"./client": {
			"types": "./src/client/subscribe.ts",
			"import": "./src/client/subscribe.ts"
		},
		"./configure": {
			"types": "./src/configure.ts",
			"import": "./src/configure.ts"
		},
		"./testing": {
			"types": "./src/testing/FakeNova.ts",
			"import": "./src/testing/FakeNova.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@c9up/atlas": "workspace:*",
		"@types/node": "*",
		"@types/web-push": "^3.6.4",
		"jsdom": "^29.1.1",
		"nock": "^14.0.14",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@c9up/ream": "workspace:*"
	},
	"dependencies": {
		"web-push": "^3.6.7"
	},
	"publishConfig": {
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			},
			"./provider": {
				"types": "./dist/NovaProvider.d.ts",
				"import": "./dist/NovaProvider.js"
			},
			"./services/main": {
				"types": "./dist/services/main.d.ts",
				"import": "./dist/services/main.js"
			},
			"./client": {
				"types": "./dist/client/subscribe.d.ts",
				"import": "./dist/client/subscribe.js"
			},
			"./configure": {
				"types": "./dist/configure.d.ts",
				"import": "./dist/configure.js"
			},
			"./testing": {
				"types": "./dist/testing/FakeNova.d.ts",
				"import": "./dist/testing/FakeNova.js"
			}
		}
	}
}
