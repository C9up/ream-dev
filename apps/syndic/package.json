{
  "name": "syndic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#modules/*": "./app/modules/*",
    "#config/*": "./config/*",
    "#exceptions/*": "./app/exceptions/*",
    "#middleware/*": "./app/middleware/*",
    "#providers/*": "./providers/*",
    "#start/*": "./start/*"
  },
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch bin/server.ts",
    "start": "node --import @swc-node/register/esm-register bin/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check app start tests reamrc.ts"
  },
  "dependencies": {
    "@c9up/atlas": "workspace:*",
    "@c9up/pulsar": "workspace:*",
    "@c9up/ream": "workspace:*",
    "@c9up/rune": "workspace:*",
    "@c9up/spectrum": "workspace:*",
    "@c9up/warden": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.24",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
