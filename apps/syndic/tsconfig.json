{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "#modules/*": ["./app/modules/*"],
      "#config/*": ["./config/*"],
      "#exceptions/*": ["./app/exceptions/*"],
      "#middleware/*": ["./app/middleware/*"],
      "#providers/*": ["./providers/*"],
      "#start/*": ["./start/*"]
    }
  },
  "include": ["app", "bin", "config", "providers", "start", "tests"]
}
